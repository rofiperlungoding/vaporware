# Supabase — copy this file to .env.local and fill in real values.
# Project URL (Project Settings → API → Project URL). Safe to expose.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Service role key (Project Settings → API → service_role secret).
# SERVER ONLY. Never expose this to the browser or commit it.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Novus.ai (Pendo) project / API key. Public by design (client analytics snippet).
NEXT_PUBLIC_NOVUS_PROJECT_ID=your-novus-project-id

# Mistral AI — SERVER ONLY (never NEXT_PUBLIC_). Powers the grounded AI verdict
# + painted-door read. If unset, the app falls back to static text everywhere.
MISTRAL_API_KEY=your-mistral-api-key
